// OnTap Dev Documentation - Prisma Schema
// MySQL hosted on Hostinger

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String
  password          String    // bcrypt hashed
  isEmailVerified   Boolean   @default(false)
  verificationToken String?   @unique
  verificationTokenExpiry DateTime?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  avatarUrl         String?   @db.LongText
  bio               String?   @db.Text
  phone             String?
  jobTitle          String?
  company           String?
  website           String?
  location          String?
  preferences        Json?
  role               UserRole  @default(USER)
  twoFactorEnabled   Boolean   @default(false)
  otpCode            String?
  otpCodeExpiry      DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil        DateTime?
  isDisabled         Boolean   @default(false)
  disabledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  projects           Project[]
  sessions           Session[]
  collaborations     ProjectCollaborator[]
  apiKeys            ApiKey[]
  trustedDevices     TrustedDevice[]

  @@index([email])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

model Project {
  id                String             @id @default(uuid())
  title             String
  description       String?            @db.Text
  category          String
  tags              String?            @db.Text  // JSON array stored as string
  visibility        ProjectVisibility  @default(PRIVATE)
  docType           String             @default("Technical Documentation")
  paperSize         PaperSize          @default(A4)
  authorId          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  coverImageUrl     String?
  versionNumber     Int                @default(1)

  author            User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sections          Section[]
  tableOfContents   TableOfContents?
  collaborators     ProjectCollaborator[]
  docSnapshots      DocSnapshot[]
  sharedLinks       SharedLink[]

  @@index([authorId])
  @@index([visibility])
}

enum ProjectVisibility {
  PRIVATE
  PUBLIC
}

enum PaperSize {
  A4
  LEGAL
  LONG
}

// ─────────────────────────────────────────────
// TABLE OF CONTENTS
// ─────────────────────────────────────────────

model TableOfContents {
  id        String   @id @default(uuid())
  projectId String   @unique
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// SECTIONS
// ─────────────────────────────────────────────

model Section {
  id          String            @id @default(uuid())
  projectId   String
  title       String
  orderIndex  Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks      ContentBlock[]

  @@index([projectId])
  @@index([orderIndex])
}

// ─────────────────────────────────────────────
// CONTENT BLOCKS
// ─────────────────────────────────────────────

model ContentBlock {
  id         String        @id @default(uuid())
  sectionId  String
  type       BlockType     @default(TEXT)
  content    String        @db.LongText  // HTML or code string
  language   String?       // programming language for code blocks
  orderIndex Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  section    Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([orderIndex])
}

enum BlockType {
  TEXT
  CODE
  IMAGE
  TABLE
  DIVIDER
}

// ─────────────────────────────────────────────
// COLLABORATORS
// ─────────────────────────────────────────────

model ProjectCollaborator {
  id                String              @id @default(uuid())
  projectId         String
  invitedEmail      String
  invitedName       String?
  userId            String?
  role              CollaboratorRole    @default(VIEWER)
  status            CollaboratorStatus  @default(PENDING)
  inviteToken       String              @unique
  inviteTokenExpiry DateTime
  hasEdited         Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([projectId, invitedEmail])
  @@index([projectId])
  @@index([inviteToken])
  @@index([userId])
}

enum CollaboratorRole {
  VIEWER
  COMMENTER
  EDITOR
}

enum CollaboratorStatus {
  PENDING
  ACCEPTED
}

// ─────────────────────────────────────────────
// API KEYS (for CLI / automation)
// ─────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  name        String                          // human-readable label, e.g. "CI Pipeline"
  prefix      String    @db.VarChar(12)       // first 8 chars of the key (for display)
  hashedKey   String    @unique               // SHA-256 hash of the full key
  scopes      String    @db.Text              // JSON array of scope strings, e.g. ["sync","read"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs   ApiUsageLog[]

  @@index([userId])
  @@index([hashedKey])
  @@index([prefix])
}

// ─────────────────────────────────────────────
// API USAGE LOGGING
// ─────────────────────────────────────────────

model ApiUsageLog {
  id        String   @id @default(uuid())
  apiKeyId  String
  endpoint  String                         // e.g. "/api/v1/projects/:id/sync"
  method    String   @db.VarChar(10)       // GET, POST, PUT, etc.
  status    Int                            // HTTP status code
  ip        String?  @db.VarChar(45)       // IPv4 or IPv6
  createdAt DateTime @default(now())

  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// DOC SNAPSHOTS (automation sync tracking)
// ─────────────────────────────────────────────

model DocSnapshot {
  id          String     @id @default(uuid())
  projectId   String
  commitHash  String?                      // git commit if available
  branch      String?                      // git branch name
  totalFiles  Int        @default(0)
  status      SyncStatus @default(PENDING)
  errorLog    String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  files       DocFile[]

  @@index([projectId])
  @@index([createdAt])
}

model DocFile {
  id          String      @id @default(uuid())
  snapshotId  String
  filePath    String      @db.VarChar(500)   // relative path in the repo
  fileHash    String      @db.VarChar(64)    // SHA-256 of file content
  language    String?                        // detected programming language
  sectionId   String?                        // linked Section in the project
  createdAt   DateTime    @default(now())

  snapshot    DocSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  symbols     DocSymbol[]

  @@index([snapshotId])
  @@index([filePath])
}

model DocSymbol {
  id          String   @id @default(uuid())
  docFileId   String
  name        String                       // function/class/method name
  kind        String   @db.VarChar(30)     // "function", "class", "method", "interface", etc.
  startLine   Int
  endLine     Int
  signature   String?  @db.Text            // full signature
  docstring   String?  @db.Text            // extracted JSDoc / docstring
  createdAt   DateTime @default(now())

  docFile     DocFile  @relation(fields: [docFileId], references: [id], onDelete: Cascade)

  @@index([docFileId])
}

enum SyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// TRUSTED DEVICES (2FA skip for known devices)
// ─────────────────────────────────────────────

model TrustedDevice {
  id          String   @id @default(uuid())
  userId      String
  deviceToken String   @unique           // random 64-char hex stored as cookie
  userAgent   String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceToken])
}

// ─────────────────────────────────────────────
// SHARED LINKS (public document access)
// ─────────────────────────────────────────────

model SharedLink {
  id          String    @id @default(uuid())
  projectId   String
  token       String    @unique           // random 64-char hex used in URL
  canEdit     Boolean   @default(false)
  canComment  Boolean   @default(false)
  canDownload Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([token])
}
